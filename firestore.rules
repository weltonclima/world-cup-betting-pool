rules_version = '2';

// Bolão dos Parças — Security Rules (TASK-08).
// Controle de acesso por dois eixos: status (pending|approved|blocked) e
// role (user|admin). As rules são a última linha de defesa: o frontend
// nunca é confiável. Modelo: só autenticado + approved enxerga as áreas
// internas; cada um escreve apenas os próprios palpites; só admin muda
// role/status de terceiros e administra dados do torneio; o auto-cadastro
// nasce sempre pending/user e não pode se auto-promover.
// Deny-by-default: qualquer path não casado é negado.
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Helpers (status/role via get() do doc do requisitante) ----
    // Curto-circuito em isSignedIn() garante que o get() nunca roda para
    // usuário não autenticado (request.auth.uid nulo invalidaria o path).
    function isSignedIn() { return request.auth != null; }

    function getUserData() {
      // Lê o doc do PRÓPRIO requisitante (users/{request.auth.uid}).
      // Se o doc ainda não existir (signup em andamento), isAdmin()/
      // isApproved() resultam false — comportamento seguro (nega).
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Role do requisitante. Dupla-compat na transição PRD-09: o valor legado
    // "admin" equivale ao canônico "super_admin" (corte do legado é TASK-12).
    // Centralizar a checagem aqui — não comparar string crua espalhada nas rules.
    function isSuperAdmin() {
      return isSignedIn() &&
        (getUserData().role == "admin" || getUserData().role == "super_admin");
    }
    function isGroupAdmin() { return isSignedIn() && getUserData().role == "group_admin"; }
    // isAdmin() preservado como alias de super_admin (todos os matches do torneio,
    // users, logs etc. continuam válidos sem reescrita — escopo TASK-06).
    function isAdmin()    { return isSuperAdmin(); }
    function isApproved() { return isSignedIn() && getUserData().status == "approved"; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }

    // ---- users: perfil/role/status ----
    // Leitura só do dono ou admin: o perfil tem e-mail/role/status e não
    // pode vazar para todos. Apelido de terceiros vem desnormalizado de
    // rankings/statistics, não desta coleção.
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();

      // Auto-cadastro força status="pending" + role de participante (impossível
      // nascer approved ou com papel administrativo). Aceita o role canônico novo
      // "participant" (PRD-09) e o legado "user" durante a transição (corte TASK-12).
      // Admin cria livre (via Admin SDK/console).
      allow create: if isAdmin() || (
        isOwner(uid) &&
        request.resource.data.status == "pending" &&
        (request.resource.data.role == "user" ||
         request.resource.data.role == "participant")
      );

      // Dono atualiza o próprio doc SEM mudar role/status; só admin muda
      // role/status (aprovar/bloquear/promover).
      allow update: if isAdmin() || (
        isOwner(uid) &&
        resource.data.keys().hasAll(["role", "status"]) &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.status == resource.data.status
      );

      allow delete: if isAdmin();
    }

    // ---- predictions: leitura PRIVADA (só dono/admin); escrita APENAS via Admin SDK ----
    // A5 (PRD-05, decidido = PRIVADO): o histórico de palpites é privado — cada
    // usuário lê apenas os PRÓPRIOS palpites; admin lê todos. Isso REVERTE o D7
    // anterior (leitura ampla por approved): a Tela 05 (Perfil) NÃO expõe palpites
    // alheios; comparações sociais usam apenas os docs derivados `rankings`/`statistics`.
    // MOTIVO DO BLOQUEIO DE WRITE CLIENT:
    //   Partidas não estão no Firestore (servidas via Route Handlers — PRD-07 v2.0).
    //   As Rules não conseguem ler `kickoffAt` para verificar o bloqueio temporal.
    //   Toda escrita passa pelo Route Handler /api/predictions (Admin SDK),
    //   que bypassa as Rules por design e aplica o lock server-side de forma
    //   autoritativa. Write client-direto é negado a todos (incluindo admin).
    match /predictions/{predictionId} {
      allow read:  if isApproved() && (isOwner(resource.data.uid) || isAdmin());
      allow write: if false; // write exclusivo do Admin SDK via Route Handler
    }

    // ---- bonus_predictions: mesma política de predictions ----
    match /bonus_predictions/{bonusId} {
      allow read:   if isApproved();
      allow create: if isApproved() && isOwner(request.resource.data.uid);
      allow update: if isApproved() && isOwner(resource.data.uid)
                                    && isOwner(request.resource.data.uid);
      allow delete: if (isApproved() && isOwner(resource.data.uid)) || isAdmin();
    }

    // ---- Coleções do torneio: approved lê, admin escreve ----
    // As Cloud Functions populam estas coleções via Admin SDK, que bypassa
    // as Security Rules por design (TASK-09). isAdmin() cobre escrita manual
    // via cliente admin.
    match /teams/{teamId}        { allow read: if isApproved(); allow write: if isAdmin(); }
    match /groups/{groupId}      { allow read: if isApproved(); allow write: if isAdmin(); }

    // ---- pools (PRD-09): grupos de bolão multi-tenant ----
    // `pools` (bolão) ≠ `groups` (grupos do torneio Copa, acima) — coleções distintas.
    // LEITURA: só usuário approved e SOMENTE pools com status=="active" — pools
    //   pending/blocked não vazam para a busca/cliente (visíveis só via Admin SDK).
    //   Rules não são filtro: uma query precisa restringir a status=="active" (a
    //   leitura de doc pending/blocked ou a query por não-ativos é negada).
    // ESCRITA negada a TODO cliente (incl. admin autenticado): criação (nasce
    //   pending), aprovação (pending→active) e bloqueio são exclusivos do Admin SDK
    //   nos Route Handlers (TASK-04/05), que bypassa as Rules por design. Espelha
    //   a política de `predictions`/`webauthn_credentials`. Isolamento de ranking
    //   por pool é TASK-11 (não aqui).
    match /pools/{poolId} {
      allow read:  if isApproved() && resource.data.status == "active";
      allow write: if false; // create/update/delete exclusivos do Admin SDK
    }
    // matches (PRD-11 TASK-03): persistência net-new da coleção de partidas.
    // LEITURA: qualquer approved. ESCRITA negada a TODO cliente (incl. admin) —
    // sync OpenFootball (`POST /api/admin/worldcup/sync`) e edição manual
    // (`PUT /api/admin/matches/[id]`) gravam exclusivamente via Admin SDK nos
    // Route Handlers, que bypassam as Rules por design. Espelha `pools`/`predictions`.
    match /matches/{matchId}     { allow read: if isApproved(); allow write: if false; }
    match /system_settings/{id}  { allow read: if isApproved(); allow write: if isAdmin(); }

    // ---- Derivados do recálculo (PRD-05): approved lê, NINGUÉM escreve pelo cliente ----
    // Gerados exclusivamente pelo Route Handler /api/rankings/recalc (Admin SDK, que
    // bypassa as Rules). Write client = negado a todos, inclusive admin.
    //
    // ISOLAMENTO POR POOL (PRD-09, CR-04): o ranking GERAL (`geral`) e os rankings por
    // POOL (`pool-{id}-geral`) NÃO são mais legíveis direto pelo client SDK — são
    // servidos só pelos Route Handlers autenticados (`/api/rankings/{scope}` e
    // `/api/rankings/pool`), que escopam por sessão. Isso impede burlar a closure
    // lendo `rankings/geral` ou `pool-{outroGrupo}-geral` pelo cliente. Os rankings
    // por GRUPO do torneio (`grupo-A`..`grupo-L`) seguem legíveis (leaderboard de fase,
    // ainda consumido client-side por `useGroupRanking`). As 5 fases (`grupos`,
    // `oitavas`…) também passam pelo Route Handler → negadas ao client direto.
    match /rankings/{scope}      { allow read: if isApproved() && scope.matches("grupo-.*"); allow write: if false; }
    match /statistics/{uid}      { allow read: if isApproved(); allow write: if false; }
    match /pool_stats/{id}       { allow read: if isApproved(); allow write: if false; }

    // ---- system_logs (PRD-07): auditoria admin-only e imutável ----
    // Gravado client-side pelo admin (sem Cloud Function — Spark). Leitura
    // admin-only (tela Logs). Sem update/delete: log é append-only (não forjável
    // a posteriori). NÃO usa isApproved pois é exclusivo de admin.
    match /system_logs/{logId} {
      allow read:   if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    // ---- sync_logs (PRD-11 TASK-03): resumo das sincronizações da Copa ----
    // Leitura EXCLUSIVA de super_admin (painel "Última Sincronização" / "Detalhes
    // do Log"). Escrita negada a TODO cliente: o resumo é gravado pelo Admin SDK
    // no Route Handler de sync. Append-only por design (sem update/delete).
    match /sync_logs/{logId} {
      allow read:  if isSuperAdmin();
      allow write: if false; // create exclusivo do Admin SDK no Route Handler
    }

    // ---- notifications (PRD-08): cada um lê as suas; admin cria p/ terceiros ----
    // Sem Cloud Function: o admin (client) cria notificação de Sistema no doc do
    // usuário-alvo (aprovação/bloqueio). O dono lê e marca como lida, sem poder
    // trocar o destinatário. Imutável quanto a `userId`; sem delete.
    match /notifications/{notificationId} {
      allow read:   if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAdmin() || isOwner(request.resource.data.userId);
      allow update: if isOwner(resource.data.userId) &&
                    request.resource.data.userId == resource.data.userId;
      allow delete: if false;
    }

    // ---- notificationPreferences (PRD-08): só o dono (doc id = uid) ----
    match /notificationPreferences/{uid} {
      allow read:           if isOwner(uid);
      allow create, update: if isOwner(uid) && request.resource.data.userId == uid;
      allow delete:         if false;
    }

    // ---- fcm_tokens (web-push-pwa TASK-03): tokens de Web Push por device ----
    // Metadado de entrega server-side. O cliente nunca lê nem escreve direto:
    // registro/remoção passam pelo Route Handler /api/push/tokens (Admin SDK,
    // que bypassa as Rules por design), e o envio (TASK-04) lê via Admin SDK.
    // Sem caminho de leitura client → read/write negados (espelha
    // `webauthn_challenge_jti`). Reabrir como `isOwner` só se a UI precisar
    // listar devices (TASK-05/06).
    match /fcm_tokens/{token} {
      allow read, write: if false;
    }

    // ---- webauthn_credentials (login biométrico, TASK-03) ----
    // Credencial de passkey. Leitura só do dono approved (lista/gestão em
    // TASK-06) ou admin; ESCRITA negada a todo cliente (incl. admin). A prova
    // criptográfica WebAuthn (attestation/assertion) não é verificável por
    // Rules → registro/login gravam via Admin SDK no Route Handler (TASK-05/07),
    // que bypassa as Rules por design. Espelha a política de `predictions`.
    match /webauthn_credentials/{credentialId} {
      allow read:  if isApproved() && (isOwner(resource.data.uid) || isAdmin());
      allow write: if false; // create/update/delete exclusivos do Admin SDK
    }

    // ---- webauthn_challenge_jti (login biométrico, TASK-07) ----
    // Store de `jti` consumidos do challenge (single-use, HR-01). Acesso
    // EXCLUSIVO do Admin SDK no Route Handler de verificação (registro/login):
    // o cliente nunca lê nem escreve — é metadado de segurança server-side.
    match /webauthn_challenge_jti/{jti} {
      allow read, write: if false;
    }

    // ---- invites (PRD-10, TASK-03): convites de entrada por pool ----
    // Isolamento por `groupId`: o approved só lê convites ATIVOS do PRÓPRIO pool
    // (`resource.data.groupId == request.auth.token.groupId`, claim populada na
    // PRD-09 TASK-06). ESCRITA negada a TODO cliente (incl. admin autenticado):
    // criação/revogação e o incremento de `usedCount` na redenção são exclusivos
    // do Admin SDK nos Route Handlers /api/group/invites (TASK-08), que bypassa as
    // Rules por design. Espelha a política de `pools`/`predictions`. NÃO assume um
    // claim `groupId` em quem não o tem — o `&&` curto-circuita em isApproved().
    match /invites/{inviteId} {
      allow read:  if isApproved() &&
                      resource.data.isActive == true &&
                      resource.data.groupId == request.auth.token.groupId;
      allow write: if false; // create/update/delete exclusivos do Admin SDK
    }

    // ---- worldcup_cache (TASK-04) ----
    // Cache server-side dos payloads derivados da fase de grupos e mata-mata
    // (docs "groups" e "bracket"), alimentado exclusivamente pelo Admin SDK
    // nos Route Handlers /api/worldcup/* a partir dos dados do openfootball.
    // O cliente nunca acessa esta coleção diretamente — dois docs no máximo.
    match /worldcup_cache/{doc} {
      allow read, write: if false; // cache server-side (Admin SDK); cliente nunca acessa
    }

    // ---- Deny-by-default: qualquer outro path ----
    // Redundante (não casar já nega), mantido como afirmação explícita.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

{
  "permissions": {
    "allow": [
      "PowerShell(*)",
      "Bash(*)",
      "Skill(*)",
      "WebSearch",
      "mcp__plugin_context7_context7__query-docs",
      "mcp__ide__getDiagnostics",
      "mcp__plugin_context7_context7__resolve-library-id"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/.claude/hooks/skill-model-guard.js\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
